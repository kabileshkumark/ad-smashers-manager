{
  "name": "ad-smashers-manager",
  "version": "1.0.1",
  "appVersion": "1.0.1",
  "private": true,
  "scripts": {
    "test": "node --test tests/*.test.js",
    "sync:version": "node scripts/sync-app-version.js",
    "build": "npm run sync:version && node scripts/prepare-firebase-hosting.js",
    "backup:firestore": "node scripts/import-firestore-state.js --backup-only",
    "export:firestore": "node scripts/export-firestore-state.js",
    "import:firestore": "node scripts/import-firestore-state.js",
    "deploy": "npm run build && firebase deploy --only hosting --project home-kaish",
    "serve": "npm run build && firebase emulators:start --only hosting --project home-kaish"
  }
}
